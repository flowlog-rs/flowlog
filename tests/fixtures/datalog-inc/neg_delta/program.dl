// ════════════════════════════════════════════════════════════════════════════
// Suite   : neg_delta
// Feature : non-recursive negation — EDB change flips negation result
// ════════════════════════════════════════════════════════════════════════════

.decl Person(id: int32)
.input Person(IO="command", delimiter=",")

.decl Blocked(id: int32)
.input Blocked(IO="command", delimiter=",")

.decl Active(id: int32)
Active(id) :- Person(id), !Blocked(id).
.output Active
