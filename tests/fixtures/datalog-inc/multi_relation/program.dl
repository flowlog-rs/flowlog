// ════════════════════════════════════════════════════════════════════════════
// Suite   : multi_relation
// Feature : single transaction updates 2 relations simultaneously
// ════════════════════════════════════════════════════════════════════════════

.decl Edge(src: int32, dst: int32)
.input Edge(IO="command", delimiter=",")

.decl Weight(src: int32, dst: int32, w: int32)
.input Weight(IO="command", delimiter=",")

.decl WeightedEdge(src: int32, dst: int32, w: int32)
WeightedEdge(s, d, w) :- Edge(s, d), Weight(s, d, w).
.output WeightedEdge
