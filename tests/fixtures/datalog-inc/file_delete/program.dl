// ════════════════════════════════════════════════════════════════════════════
// Suite   : file_delete
// Feature : file command with -1 bulk-deletes CSV contents
// ════════════════════════════════════════════════════════════════════════════

.decl Data(id: int32, val: int32)
.input Data(IO="command", delimiter=",")

.decl Out(id: int32, val: int32)
Out(id, v) :- Data(id, v).
.output Out
