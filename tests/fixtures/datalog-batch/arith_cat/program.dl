// ════════════════════════════════════════════════════════════════════════════
// Suite   : arith_cat
// Feature : string concatenation built-in `cat(a, b)` in rule head
// Covers  : var+var, literal+var, nested (multi-arg) cat
// ════════════════════════════════════════════════════════════════════════════

.decl First(id: int32, name: string)
.input First(IO="file", filename="First.csv", delimiter=",")

.decl Last(id: int32, name: string)
.input Last(IO="file", filename="Last.csv", delimiter=",")

.decl Full(id: int32, name: string)
Full(id, cat(f, cat(" ", l))) :- First(id, f), Last(id, l).
.output Full

.decl Greeting(id: int32, msg: string)
Greeting(id, cat("Hello ", n)) :- First(id, n).
.output Greeting
