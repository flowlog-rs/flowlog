// ════════════════════════════════════════════════════════════════════════════
// Suite   : udf_predicate
// Feature : UDF as boolean filter in rule body. UDFs are value-only, so a
//           boolean UDF filters via comparison: `f(x) = True` / `f(x) = False`.
// ════════════════════════════════════════════════════════════════════════════

.extern fn is_prime(n: int32) -> bool

.decl Data(id: int32, val: int32)
.input Data(IO="file", filename="Data.csv", delimiter=",")

.decl PrimeVal(id: int32, val: int32)
PrimeVal(id, val) :- Data(id, val), is_prime(val) = True.
.output PrimeVal

.decl CompositeVal(id: int32, val: int32)
CompositeVal(id, val) :- Data(id, val), is_prime(val) = False.
.output CompositeVal
