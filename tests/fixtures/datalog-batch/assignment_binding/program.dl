// ════════════════════════════════════════════════════════════════════════════
// Suite   : assignment_binding
// Feature : Soufflé assignment-style equalities, where a variable is *defined*
//           by an equality rather than range-restricted by a positive atom.
//           FlowLog's grounding pass desugars these by substitution; a rule
//           that collapses to an empty body with an all-constant head becomes
//           an inline fact. Mirrors DOOP's `isModifier(x) :- x = "abstract"`.
//
//           Expected/*.csv generated by Soufflé 2.5 on the same input; this
//           fixture passes iff flowlog reproduces them byte-for-byte.
// ════════════════════════════════════════════════════════════════════════════

.decl Inp(x: number)
.input Inp(IO="file", filename="Inp.csv", delimiter=",")

// Multi-head constant binding, empty body → two ground facts (A(7), B(7)).
.decl A(x: number)
.decl B(x: number)
.output A
.output B
A(v), B(v) :- v = 7.

// Constant binding with a residual positive atom → constant inlined, body kept.
.decl C(c: number, y: number)
.output C
C(c, y) :- c = 100, Inp(y).

// var = var (the lone side unbound) → rename to the bound variable.
.decl D(x: number)
.output D
D(y) :- Inp(x), y = x.

// var = expr (compound, used only in the head) → folded into head arithmetic.
.decl E(z: number)
.output E
E(z) :- Inp(x), z = x + 1.
