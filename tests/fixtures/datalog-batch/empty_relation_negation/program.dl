// ════════════════════════════════════════════════════════════════════════════
// Suite   : empty_relation_negation
// Feature : Soufflé-compat empty relation. `Excluded` is declared but has no
//           rule, no inline facts, and no `.input`, so in Soufflé it is simply
//           an empty relation: a negated use `!Excluded(x)` always holds and a
//           positive use `Excluded(x)` never fires. FlowLog previously rejected
//           the negated reference with a stratifier "not yet defined" error;
//           prune now registers such declared-but-underived relations as empty
//           EDBs so they are available before the first stratum.
//
//           Expected/*.csv generated by Soufflé 2.5 on the same Node input;
//           this fixture passes iff flowlog produces byte-identical outputs.
// ════════════════════════════════════════════════════════════════════════════

.decl Node(x: number)
.input Node(IO="file", filename="Node.csv", delimiter=",")

// Declared, never derived, no facts, no .input → empty relation.
.decl Excluded(x: number)

// Negated use of an empty relation is always satisfied → Kept == Node.
.decl Kept(x: number)
.output Kept
Kept(x) :- Node(x), !Excluded(x).

// Positive use of an empty relation never fires → Dropped is empty.
.decl Dropped(x: number)
.output Dropped
Dropped(x) :- Node(x), Excluded(x).
