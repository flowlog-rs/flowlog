// ════════════════════════════════════════════════════════════════════════════
// Suite   : multi_head_multi_body
// Feature : Souffle-style combined multi-head and multi-body rules
// Covers  : C; D :- A; B. expands to C:-A. C:-B. D:-A. D:-B.
// ════════════════════════════════════════════════════════════════════════════

.decl A(x: int32)
.input A(IO="file", filename="A.csv", delimiter=",")

.decl B(x: int32)
.input B(IO="file", filename="B.csv", delimiter=",")

.decl C(x: int32)
.decl D(x: int32)

// Cross product: both heads derive from both bodies
C(X); D(X) :- A(X); B(X).

.output C
.output D
