// ════════════════════════════════════════════════════════════════════════════
// Suite   : _souffle_parity   (leading "_" sorts it after other fixtures)
// Feature : Output parity vs. Soufflé 2.5 on every construct added by
//           the DOOP gap-fill PR — body aggregates, paren arithmetic,
//           negated atom with parens, match() regex builtin.
//
//           Expected/*.csv values were generated by Soufflé on the same
//           Edge/Node inputs. This fixture passes iff flowlog produces
//           byte-identical (sorted) outputs.
// ════════════════════════════════════════════════════════════════════════════

.decl Edge(src: number, dst: number, w: number)
.input Edge(IO="file", filename="Edge.csv", delimiter=",")

.decl Node(id: number, name: symbol)
.input Node(IO="file", filename="Node.csv", delimiter=",")

// --- Gap 1: body-aggregate min ----------------------------------------------
.decl MinOutW(src: number, mw: number)
.output MinOutW
MinOutW(s, mw) :-
  Edge(s, _, _),
  mw = min w : { Edge(s, _, w) }.

// --- Gap 1: body-aggregate count (K=1, single body var) ---------------------
// Project Edge to its destination column first, then count distinct
// destinations per source. This is the K=1 shape flowlog supports
// today; K>=2 is intentionally rejected.
.decl EdgeDst(src: number, dst: number)
EdgeDst(s, d) :- Edge(s, d, _).

.decl OutDegree(src: number, deg: number)
.output OutDegree
OutDegree(s, deg) :-
  EdgeDst(s, _),
  deg = count : { EdgeDst(s, d) }.

// --- Gap 2: parenthesized arith at boundary, plus Gap 3: !(Atom) ------------
.decl CloseHeavy(src: number, dst: number)
.output CloseHeavy
CloseHeavy(s, d) :-
  Edge(s, d, w),
  (w + 0) >= 5,
  !(Edge(d, s, _)).

// --- Gap 4: match(regex, string) and its negation ---------------------------
.decl JavaNode(id: number)
.output JavaNode
JavaNode(id) :- Node(id, n), match("java[.].*", n).

.decl NonJavaNode(id: number)
.output NonJavaNode
NonJavaNode(id) :- Node(id, n), !match("java[.].*", n).
