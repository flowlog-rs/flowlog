// ════════════════════════════════════════════════════════════════════════════
// Suite   : recursive_max
// Feature : recursive max aggregation in datalog-batch mode
// Covers  : compilation + execution of max() under recursive propagation
//
// Data layout
//   Source(node:i32)               — single seed node 1
//   Edge(src:i32, dst:i32, w:i32) — weighted DAG with multiple paths
//
// Expected longest distances from source 1:
//   1 -> 1 : 0
//   1 -> 2 : 5   via direct edge
//   1 -> 3 : 1
//   1 -> 4 : 11  via 1 -> 3 -> 4
//   1 -> 5 : 14  via 1 -> 2 -> 5
// ════════════════════════════════════════════════════════════════════════════

.decl Source(node: int32)
.input Source(IO="file", filename="Source.csv", delimiter=",")

.decl Edge(src: int32, dst: int32, weight: int32)
.input Edge(IO="file", filename="Edge.csv", delimiter=",")

.decl MaxDist(node: int32, dist: int32)
MaxDist(s, max(0)) :- Source(s).
MaxDist(y, max(d + w)) :- MaxDist(x, d), Edge(x, y, w).

.output MaxDist
