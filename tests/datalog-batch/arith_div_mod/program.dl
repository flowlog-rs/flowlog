// ════════════════════════════════════════════════════════════════════════════
// Suite   : arith_div_mod
// Feature : integer division (/) and modulo (%) operators
// Covers  : head arithmetic with / and %, combined / and % in one rule head,
//           integer truncation on positive dividends, modulo in body filter,
//           chained * and / in single head expression (left-to-right eval),
//           sum aggregation over a division expression
// ════════════════════════════════════════════════════════════════════════════

// ── EDB ──────────────────────────────────────────────────────────────────────

.decl Numbers(a: int32, b: int32)
.input Numbers(IO="file", filename="Numbers.csv", delimiter=",")

// ── TEST DivResult: integer division ─────────────────────────────────────────
// Verifies : a / b produces truncated integer quotient.
// Sample   : 10 / 3 = 3,  20 / 4 = 5,  7 / 2 = 3

.decl DivResult(a: int32, b: int32, q: int32)
DivResult(a, b, a / b) :- Numbers(a, b).
.output DivResult

// ── TEST ModResult: modulo operator ──────────────────────────────────────────
// Verifies : a % b produces the remainder.
// Sample   : 10 % 3 = 1,  20 % 4 = 0,  7 % 2 = 1

.decl ModResult(a: int32, b: int32, r: int32)
ModResult(a, b, a % b) :- Numbers(a, b).
.output ModResult

// ── TEST DivMod: combined quotient and remainder in single rule ──────────────
// Verifies : both / and % can appear in the same rule head.

.decl DivMod(a: int32, b: int32, q: int32, r: int32)
DivMod(a, b, a / b, a % b) :- Numbers(a, b).
.output DivMod

// ── TEST EvenFilter: modulo used in comparison filter ────────────────────────
// Verifies : a % 2 = 0 correctly identifies even dividends.
// Sample   : 10, 20, 100 are even; 7, 15 are odd

.decl EvenDividend(a: int32, b: int32)
EvenDividend(a, b) :- Numbers(a, b), a % 2 = 0.
.output EvenDividend

// ── TEST ScaledDiv: division combined with multiplication ────────────────────
// Verifies : chaining * and / in the same head expression.
//            Computes (a * 10) / b — tests operator left-to-right precedence.
// Sample   : a=10, b=3 → (10*10)/3 = 100/3 = 33

.decl ScaledDiv(a: int32, b: int32, result: int32)
ScaledDiv(a, b, a * 10 / b) :- Numbers(a, b).
.output ScaledDiv

// ── TEST SumOfQuotients: aggregation over division result ────────────────────
// Verifies : sum() applied to a / expression across all rows.

.decl SumQuotients(total: int32)
SumQuotients(sum(a / b)) :- Numbers(a, b).
.output SumQuotients
