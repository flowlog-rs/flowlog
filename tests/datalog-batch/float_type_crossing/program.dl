// ════════════════════════════════════════════════════════════════════════════
// Suite   : float_type_crossing
// Feature : floating-point type boundaries (f32 / f64) used as join keys
//           and in mixed-width outputs
// Covers  : f32 join key, f64 join key, IDB-to-EDB join spanning strata,
//           multiple rules feeding one IDB (type unification), float literal
//           constants (f32 and f64) in typed columns
//
// Data layout (all values binary-exact to avoid display ambiguity)
//   A  (x:f32, y:f32)    — x ∈ {1.5, 3.5, 5.5}
//   B  (x:f32, z:f64)    — same x keys as A; z ∈ {10.0, 20.0, 30.0}
//   C  (z:f64, w:f32)    — keyed on z matching B's z column
// ════════════════════════════════════════════════════════════════════════════

// ── EDB ──────────────────────────────────────────────────────────────────────

.decl A(x: f32, y: f32)
.input A(IO="file", filename="A.csv", delimiter=",")

.decl B(x: f32, z: f64)
.input B(IO="file", filename="B.csv", delimiter=",")

.decl C(z: f64, w: f32)
.input C(IO="file", filename="C.csv", delimiter=",")

// ── TEST AB: 2-way join on f32 key producing (f32 × f32 × f64) output ────────
// Verifies : f32 values work as join keys (OrderedFloat hashing/equality);
//            a mixed f32/f64 output tuple is constructed without type errors.
// Sample   : A(1.5, 2.5), B(1.5, 10.0) → AB(1.5, 2.5, 10.0)

.decl AB(x: f32, y: f32, z: f64)
AB(x, y, z) :- A(x, y), B(x, z).
.output AB

// ── TEST BC: 2-way join on f64 key producing (f32 × f64 × f32) output ────────
// Verifies : f64 values work as join keys; the result carries the original
//            f32 source x alongside the f64 key and f32 value from C.
// Sample   : B(1.5, z=10.0), C(10.0, w=0.25) → BC(1.5, 10.0, 0.25)

.decl BC(x: f32, z: f64, w: f32)
BC(x, z, w) :- B(x, z), C(z, w).
.output BC

// ── TEST ABC: IDB-to-EDB join — AB (IDB, stratum 1) joined with C on f64 key ──
// Verifies : type metadata of IDB relation AB (f32, f32, f64) is carried
//            correctly into a later stratum; the f64 column z from AB serves
//            as the join key against EDB relation C.
// Sample   : AB(1.5, 2.5, z=10.0), C(10.0, 0.25) → ABC(1.5, 2.5, 10.0, 0.25)

.decl ABC(x: f32, y: f32, z: f64, w: f32)
ABC(x, y, z, w) :- AB(x, y, z), C(z, w).
.output ABC

// ── TEST Multi: two rules feeding the same f32 IDB ────────────────────────────
// Verifies : both rules produce (f32, f32) tuples; the union contains the
//            A-derived values (y) and BC-derived values (w) for each x,
//            without type errors or duplicate elimination across different values.
// Sample   : A(1.5, y=2.5)  → Multi(1.5, 2.5)  via rule 1
//            BC(1.5,_,w=0.25)→ Multi(1.5, 0.25) via rule 2
//            → both present, two distinct tuples for x=1.5

.decl Multi(x: f32, v: f32)
Multi(x, y) :- A(x, y).
Multi(x, w) :- BC(x, _, w).
.output Multi

// ── TEST WithConst: float literal constants in typed positions ─────────────────
// Verifies : float literal 1.25 is accepted as an f32 column value and 2.75
//            as an f64 column value; both are binary-exact so no rounding.
// Sample   : A(1.5,_) → WithConst(1.5, 1.25, 2.75)
//            A(3.5,_) → WithConst(3.5, 1.25, 2.75)

.decl WithConst(x: f32, tag: f32, big: f64)
WithConst(x, 1.25, 2.75) :- A(x, _).
.output WithConst
