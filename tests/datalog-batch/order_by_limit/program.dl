// ════════════════════════════════════════════════════════════════════════════
// Suite   : order_by_limit
// Feature : ORDER BY and LIMIT on output in batch mode
// Covers  : in-memory buffer merging with sort and truncation
//
// Data: Scores(name, subject, score) — student test scores
// Tests:
//   OrderByOnly     — ORDER BY on string column (no limit)
//   OrderByLimit    — ORDER BY score DESC + LIMIT 3 (top 3 scores)
//   MixedTypeSort   — ORDER BY on mixed types: int ASC, string DESC
//   OrderByLimitAsc — ORDER BY score ASC + LIMIT 4 (bottom 4 scores)
//   AllScores       — no order_by/limit (plain output, baseline)
// ════════════════════════════════════════════════════════════════════════════

.decl Scores(name: string, subject: string, score: int32)
.input Scores(IO="file", filename="Scores.csv", delimiter=",")

// ORDER BY only: sorted by name ascending (string sort).
.decl OrderByOnly(name: string, subject: string, score: int32)
OrderByOnly(n, s, sc) :- Scores(n, s, sc).
.output OrderByOnly(delimiter=",", order_by="name")

// ORDER BY + LIMIT: top 3 scores descending.
.decl OrderByLimit(name: string, subject: string, score: int32)
OrderByLimit(n, s, sc) :- Scores(n, s, sc).
.output OrderByLimit(delimiter=",", order_by="score DESC", limit="3")

// Mixed type sort: ORDER BY score ASC (int), then name DESC (string).
// Tests type-aware comparison across different column types.
.decl MixedTypeSort(name: string, subject: string, score: int32)
MixedTypeSort(n, s, sc) :- Scores(n, s, sc).
.output MixedTypeSort(delimiter=",", order_by="score ASC, name DESC")

// ORDER BY + LIMIT: bottom 4 scores ascending.
.decl OrderByLimitAsc(name: string, subject: string, score: int32)
OrderByLimitAsc(n, s, sc) :- Scores(n, s, sc).
.output OrderByLimitAsc(delimiter=",", order_by="score ASC", limit="4")

// Plain output — no sort or limit (baseline correctness).
.decl AllScores(name: string, subject: string, score: int32)
AllScores(n, s, sc) :- Scores(n, s, sc).
.output AllScores(delimiter=",")
