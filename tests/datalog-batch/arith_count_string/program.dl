// ════════════════════════════════════════════════════════════════════════════
// Suite   : arith_count_string
// Feature : count aggregation over string-typed expression from an IDB
// Covers  : count(string_var) where the input relation is a derived IDB,
//           not an EDB — the aggregated expression type (string) differs
//           from the count result type (int32)
//
// Regression test for: compiler panic "type mismatch for fingerprint"
// when count() is applied to a string column from an IDB.
// ════════════════════════════════════════════════════════════════════════════

// ── EDB ──────────────────────────────────────────────────────────────────────

.decl Person(id: int32, name: string)
.input Person(IO="file", filename="Person.csv", delimiter=",")

// ── Derived IDB ──────────────────────────────────────────────────────────────

.decl Staff(id: int32, name: string)
Staff(id, n) :- Person(id, n).

// ── TEST NameCount: count(string) over IDB ───────────────────────────────────
// Verifies : count() over a string column from a derived IDB compiles and
//            produces the correct count of distinct name values.
// Expected : 3 (alice, bob, charlie)

.decl NameCount(cnt: int32)
NameCount(count(n)) :- Staff(_, n).
.output NameCount
