// ════════════════════════════════════════════════════════════════════════════
// Suite   : loop_stop_relation
// Feature : loop block with BoolRelation stop condition (`loop stop { Done }`)
//           with TWO rules contributing to Reach — exercises the multi-head
//           union path: next_Reach = t_{head1_fp}.concat(t_{head2_fp}).concat(in_reach)
//
// Reach extends via two edge types simultaneously: Edge (one-hop) and
// Shortcut (two-hop skip).  Done() fires when node 1 reaches Target.
// Target = {2} means Done fires in round 1 via the entered delta (1,2),
// so the loop stops before round 2.  Round 1 still produces new pairs via
// both rules — including the Shortcut-derived (1,4) — but (1,5) and (2,5)
// are never computed because the feedback is suppressed after round 1.
//
// Data layout
//   Edge     — chain 1→2→3→4→5
//   Shortcut — {(2,4)}  (skip node 3)
//   Target   — {2}
//
// Evaluation trace:
//   Before loop : Reach = {(1,2),(2,3),(3,4),(4,5)}  (from Edge base rule)
//   Round 1     : iter_reach delta = entered set (above)
//                 Done rule: (1,2) in delta ∧ Target(2) → Done()
//                 Gate fires → feedback suppressed, loop stops.
//                 (round 1 new Reach still computed: {(1,3),(2,4),(3,5),(1,4)})
//
// Expected
//   Reach = {(1,2),(1,3),(1,4),(2,3),(2,4),(3,4),(3,5),(4,5)}
//           — (1,5) and (2,5) are NOT computed (would need round 2)
//   Done  = {()}
// ════════════════════════════════════════════════════════════════════════════

.decl Edge(src: int32, dst: int32)
.input Edge(IO="file", filename="Edge.csv", delimiter=",")

.decl Shortcut(src: int32, dst: int32)
.input Shortcut(IO="file", filename="Shortcut.csv", delimiter=",")

.decl Target(node: int32)
.input Target(IO="file", filename="Target.csv", delimiter=",")

.decl Reach(src: int32, dst: int32)
.decl Done()

Reach(X, Y) :- Edge(X, Y).

loop stop { Done } {
    Reach(X, Z) :- Reach(X, Y), Edge(Y, Z).
    Reach(X, Z) :- Reach(X, Y), Shortcut(Y, Z).
    Done()      :- Reach(1, Y), Target(Y).
}

.output Reach
.output Done
