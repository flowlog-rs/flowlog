// ════════════════════════════════════════════════════════════════════════════
// Suite   : loop_fixpoint
// Feature : loop block with implicit fixpoint (no stop condition)
//
// The base rule (Reach(X,Y) :- Edge(X,Y)) runs in a plain stratum before the
// loop.  The loop block contains only the recursive step, which extends Reach
// until fixpoint.  This verifies that `loop { }` (no condition) computes the
// same transitive closure as an implicit recursive stratum.
//
// Data layout
//   Edge (src: int32, dst: int32)  — edges (1,2) (2,3) (3,4)
//
// Expected
//   Reach = full transitive closure
//         = {(1,2),(1,3),(1,4),(2,3),(2,4),(3,4)}
// ════════════════════════════════════════════════════════════════════════════

.decl Edge(src: int32, dst: int32)
.input Edge(IO="file", filename="Edge.csv", delimiter=",")

.decl Reach(src: int32, dst: int32)

Reach(X, Y) :- Edge(X, Y).

loop {
    Reach(X, Z) :- Reach(X, Y), Edge(Y, Z).
}

.output Reach
