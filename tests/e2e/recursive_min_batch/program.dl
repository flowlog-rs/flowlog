// ════════════════════════════════════════════════════════════════════════════
// Suite   : recursive_min_batch
// Feature : recursive min aggregation in datalog-batch mode
// Covers  : compilation + execution of min() under recursive propagation
//
// Data layout
//   Source(node:i32)               — single seed node 1
//   Edge(src:i32, dst:i32, w:i32) — weighted DAG with multiple paths
//
// Expected shortest distances from source 1:
//   1 -> 1 : 0
//   1 -> 3 : 1
//   1 -> 2 : 2   via 1 -> 3 -> 2
//   1 -> 4 : 4   via 1 -> 3 -> 2 -> 4
//   1 -> 5 : 5   via 1 -> 3 -> 2 -> 4 -> 5
// ════════════════════════════════════════════════════════════════════════════

.decl Source(node: int32)
.input Source(IO="file", filename="Source.csv", delimiter=",")

.decl Edge(src: int32, dst: int32, weight: int32)
.input Edge(IO="file", filename="Edge.csv", delimiter=",")

.decl MinDist(node: int32, dist: int32)
MinDist(s, min(0)) :- Source(s).
MinDist(y, min(d + w)) :- MinDist(x, d), Edge(x, y, w).

.output MinDist
