// ════════════════════════════════════════════════════════════════════════════
// Suite   : loop_iterative_party_invite
// Feature : iterative (replacement) semantics for cnt (declared with
//           `iterative`), accumulative semantics for attend.
//
// Models a party invitation cascade: organizers always attend; anyone with
// at least 3 attending friends also attends.  cnt is recomputed each
// iteration (iterative) while attend only grows (accumulative).
//
// Graph (10 people, friendships symmetric):
//
//   Organizers : {1, 2, 3}
//
//   4  — friends with 1, 2, 3        (3 organizer friends → round 1)
//   5  — friends with 1, 2, 3        (3 organizer friends → round 1)
//   6  — friends with 2, 4, 5        (round 1: 2 attends; round 2: 4,5 attend → 3 → round 2)
//   7  — friends with 1, 4, 6        (round 2: 1,4 attend; round 3: 6 attends → 3 → round 3)
//   8  — friends with 1, 2           (only 2 attending friends → never)
//   9  — friends with 8, 10          (no attending friends → never)
//   10 — friends with 9              (no attending friends → never)
//
// Evaluation trace (cnt is iterative, attend is accumulative):
//   Pre-loop : attend = {1, 2, 3}
//
//   Round 1  : cnt = {(4,3),(5,3),(6,1),(7,1),(8,2),...}
//              attend += {4, 5}
//   Round 2  : cnt recomputed with attend = {1,2,3,4,5}
//              cnt(6) = 3 (friends 2,4,5 all attend)
//              attend += {6}
//   Round 3  : cnt recomputed with attend = {1,2,3,4,5,6}
//              cnt(7) = 3 (friends 1,4,6 all attend)
//              attend += {7}
//   Round 4  : cnt recomputed, no new cnt ≥ 3 → fixpoint
//
// Expected
//   attend = {1, 2, 3, 4, 5, 6, 7}
// ════════════════════════════════════════════════════════════════════════════

.decl organizer(x: int32)
.input organizer(IO="file", filename="organizer.csv", delimiter=",")

.decl friend(x: int32, y: int32)
.input friend(IO="file", filename="friend.csv", delimiter=",")

.decl attend(x: int32)
.decl cnt(x: int32, n: int32)

attend(x) :- organizer(x).

fixpoint {
    .iterative cnt
    cnt(y, count(x)) :- attend(x), friend(y, x).
    attend(x) :- cnt(x, n), n >= 3.
}

.output attend
