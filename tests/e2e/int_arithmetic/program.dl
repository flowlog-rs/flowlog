// ════════════════════════════════════════════════════════════════════════════
// Suite   : int_arithmetic
// Feature : signed integer arithmetic across widths (i8 / i16 / i32)
// Covers  : multi-way join, head arithmetic (+, *, literal constant),
//           comparison filter (>), aggregation (sum, average, count)
//
// Data layout
//   Edge   (src:i8, dst:i8)              — src=1 has two edges (→2, →3)
//                                           so aggregations are non-trivial
//   Weight (src:i8, dst:i8, w:i16)
//   Score  (node:i8, s:i32)
// ════════════════════════════════════════════════════════════════════════════

// ── EDB ──────────────────────────────────────────────────────────────────────

.decl Edge(src: int8, dst: int8)
.input Edge(IO="file", filename="Edge.csv", delimiter=",")

.decl Weight(src: int8, dst: int8, w: int16)
.input Weight(IO="file", filename="Weight.csv", delimiter=",")

.decl Score(node: int8, s: int32)
.input Score(IO="file", filename="Score.csv", delimiter=",")

// ── TEST Joined: 3-way join with mixed-width arithmetic in the head ───────────
// Verifies : i8 join keys propagate through Edge ⋈ Weight ⋈ Score;
//            head expressions w+1 and sc+1 stay in their declared widths
//            (i16 and i32 respectively).
// Sample   : Edge(1,2), Weight(1,2, w=10), Score(2, sc=500)
//            → Joined(1, 11, 501)

.decl Joined(src: int8, ww: int16, sc1: int32)
Joined(s, w + 1, sc + 1) :- Edge(s, d), Weight(s, d, w), Score(d, sc).
.output Joined

// ── TEST Filtered: comparison filter + multiplication + literal constant ───────
// Verifies : body comparison (sc > 500) prunes tuples before projection;
//            multiplication (sc * 2) and an i16 literal (77) are correctly
//            typed in the output columns.
// Sample   : Edge(3,4), Score(3, sc=600)  — 600 > 500 passes
//            → Filtered(4, 1200, 77)
//            Score(2,500) — 500 > 500 fails, no output for src=2

.decl Filtered(dst: int8, doubled: int32, tag: int16)
Filtered(d, sc * 2, 77) :- Edge(s, d), Score(s, sc), sc > 500.
.output Filtered

// ── TEST AggJoin: sum aggregation over multiple contributions per group ────────
// Verifies : sum() accumulates more than one value when a group key (src)
//            maps to multiple matching tuples.
// Sample   : src=1 joins Score(2,500) and Score(3,600)
//            → AggJoin(1, 1100)    [500 + 600, not merely 500]
//            src=2 joins only Score(3,600)
//            → AggJoin(2, 600)

.decl AggJoin(src: int8, total: int32)
AggJoin(s, sum(sc)) :- Edge(s, d), Weight(s, d, _), Score(d, sc).
.output AggJoin

// ── TEST AvgJoin: average aggregation with integer (truncating) division ───────
// Verifies : average() over integer types performs integer (floor) division
//            and aggregates across all matching tuples for a group.
// Sample   : src=1 → average(500, 600) = 1100 / 2 = 550  (exact)
//            src=2 → average(600)       = 600  / 1 = 600
//            src=5 → average(-250)      = -250 / 1 = -250

.decl AvgJoin(src: int8, mean: int32)
AvgJoin(s, average(sc)) :- Edge(s, d), Weight(s, d, _), Score(d, sc).
.output AvgJoin

// ── TEST CountJoin: count aggregation over a 2-way join ──────────────────────
// Verifies : count(sc) produces the number of (Edge, Score) tuples per src;
//            sc (i32) is used as the count expression so its type matches the
//            declared i32 column — count ignores the actual value and counts
//            the number of distinct body-tuples.
// Sample   : src=1 matches (Edge(1,2),Score(2,500)) and (Edge(1,3),Score(3,600))
//            → CountJoin(1, 2)
//            src=2 matches only (Edge(2,3),Score(3,600))
//            → CountJoin(2, 1)

.decl CountJoin(src: int8, n: int32)
CountJoin(s, count(sc)) :- Edge(s, d), Score(d, sc).
.output CountJoin
