// ════════════════════════════════════════════════════════════════════════════
// Suite   : loop_iterative_k_core
// Feature : loop iterative { ... } — iterative (replacement) semantics for
//           active_edge and degree, accumulative semantics for removed.
//
// Computes the 3-core of a directed graph (edges represented in both
// directions).  Iteratively remove every node whose active-neighbour count
// drops below 3.
//
// Graph (16 undirected edges, 32 directed):
//
//   Core K4  : 1-2, 1-3, 1-4, 2-3, 2-4, 3-4  (each node has degree ≥ 3)
//
//   Periphery:
//     5 — 1, 7          (initial degree 2  → removed round 1)
//     6 — 2, 7          (initial degree 2  → removed round 1)
//     9 — 7, 10         (initial degree 2  → removed round 1)
//    10 — 9             (initial degree 1  → removed round 1)
//    11 — 8             (initial degree 1  → removed round 1)
//    12 — 4, 8          (initial degree 2  → removed round 1)
//
//     7 — 5, 6, 8, 9    (initial degree 4; after round 1 → degree 1 → removed round 2)
//     8 — 7, 11, 12     (initial degree 3; after round 1 → degree 1 → removed round 2)
//
// Evaluation trace
//   Pre-loop: active_edge ← all 32 edges  (non-recursive stratum, EDB base)
//
//   DD inner steps (active_edge seeded via Variable::new_from — no bootstrap):
//   Step 0  : degree ← {1→4, 2→4, 3→3, 4→4, 5→2, 6→2, 7→4, 8→3, 9→2, 10→1, 11→1, 12→2}
//   Step 1  : removed ← {5,6,9,10,11,12}   (degree < 3)
//   Step 2  : active_edge ← 14 edges (core K4 + 7↔8)
//   Step 3  : degree ← {1→3, 2→3, 3→3, 4→3, 7→1, 8→1}
//   Step 4  : removed ← {5,6,7,8,9,10,11,12}  (7 and 8 now have degree 1)
//   Step 5  : active_edge ← 12 core-only edges
//   Step 6  : degree ← {1→3, 2→3, 3→3, 4→3}
//   Step 7  : no new removals → converged
//
// Expected
//   removed     = {5, 6, 7, 8, 9, 10, 11, 12}
//   active_edge = K4 directed edges (12 edges)
// ════════════════════════════════════════════════════════════════════════════

.decl edge(x: int32, y: int32)
.input edge(IO="file", filename="edge.csv", delimiter=",")

.decl active_edge(x: int32, y: int32)
.decl degree(x: int32, d: int32)
.decl removed(x: int32)

active_edge(x, y) :- edge(x, y).

loop iterative { active_edge, degree } {
    active_edge(x, y) :- edge(x, y), !removed(x), !removed(y).
    degree(x, count(y)) :- active_edge(x, y).
    removed(x) :- degree(x, d), d < 3.
}

.output removed
.output active_edge
