// ════════════════════════════════════════════════════════════════════════════
// Suite   : insert
// Feature : put command inserts tuples, verify _t1 all +1
// ════════════════════════════════════════════════════════════════════════════

.decl Edge(src: int32, dst: int32)
.input Edge(IO="file", filename="Edge.csv", delimiter=",")

.decl Out(src: int32, dst: int32)
Out(s, d) :- Edge(s, d).
.output Out
