// ════════════════════════════════════════════════════════════════════════════
// Suite   : join_delta
// Feature : non-recursive join — EDB change propagates through join to IDB
// ════════════════════════════════════════════════════════════════════════════

.decl Employee(id: int32, dept: int32)
.input Employee(IO="file", filename="Employee.csv", delimiter=",")

.decl Dept(id: int32, budget: int32)
.input Dept(IO="file", filename="Dept.csv", delimiter=",")

.decl EmpBudget(emp: int32, budget: int32)
EmpBudget(e, b) :- Employee(e, d), Dept(d, b).
.output EmpBudget
