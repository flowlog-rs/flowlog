// ════════════════════════════════════════════════════════════════════════════
// Suite   : recursive_max_delta
// Feature : recursive max aggregation in datalog-inc mode
// Focus   : after deleting an edge, the maintained maximum must decrease
//
// Initial longest distances from source 1:
//   1 -> 1 : 0
//   1 -> 2 : 5
//   1 -> 3 : 1
//   1 -> 4 : 11
//   1 -> 5 : 14   via 1 -> 2 -> 5
//
// After deleting edge (2,5,9):
//   1 -> 5 : 12   via 1 -> 3 -> 4 -> 5
// ════════════════════════════════════════════════════════════════════════════

.decl Source(node: int32)
.input Source(IO="file", filename="Source.csv", delimiter=",")

.decl Edge(src: int32, dst: int32, weight: int32)
.input Edge(IO="file", filename="Edge.csv", delimiter=",")

.decl MaxDist(node: int32, dist: int32)
MaxDist(s, max(0)) :- Source(s).
MaxDist(y, max(d + w)) :- MaxDist(x, d), Edge(x, y, w).

.output MaxDist
