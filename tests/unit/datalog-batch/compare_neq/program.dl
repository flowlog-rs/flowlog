// ════════════════════════════════════════════════════════════════════════════
// Suite   : compare_neq
// Feature : not-equal (!=) comparison filter in rule body
// ════════════════════════════════════════════════════════════════════════════

.decl Data(id: int32, val: int32)
.input Data(IO="file", filename="Data.csv", delimiter=",")

.decl Out(id: int32, val: int32)
Out(id, v) :- Data(id, v), v != 50.
.output Out
